# 环境变量配置文件
VITE_ENV=pro

# ============================================
# 🌐 网络配置
# ============================================

# 代理前缀
VITE_APP_BASE_API='/admin/v1'

# 接口地址
VITE_APP_API_URL=https://api.demo.admin.gowind.cloud

# SSE地址
VITE_APP_SSE_URL=https://sse.demo.admin.gowind.cloud/events

# ============================================
# 🎛️ 功能开关
# ============================================
# 多租户（需与后端 app.tenant.enabled 保持一致）
VITE_APP_TENANT_ENABLED=true
