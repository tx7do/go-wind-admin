# 开发环境配置
# 可选值：dev, test, pre, prod
REACT_APP_ENV=dev

# 是否启用 Mock 数据
REACT_APP_MOCK=false

# 是否启用分析
REACT_APP_ANALYZE=false

# 应用标题
REACT_APP_TITLE="GoWind Admin"

# 应用命名空间，用于缓存、store等功能的前缀，确保隔离
REACT_APP_NAMESPACE="gowind-admin"

# AES 加密密钥 (用于密码加密)
REACT_AES_KEY="f51d66a73d8a0927"

# API 基础地址
REACT_APP_API_URL="https://api.demo.admin.gowind.cloud"

# SSE地址
REACT_APP_SSE_URL="https://sse.demo.admin.gowind.cloud/events"
